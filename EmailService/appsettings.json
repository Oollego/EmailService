{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "EmailOptions": {
        "SendDelayMilliseconds": 100,
        "MaxRetryCount": 3,
        "RetryIntervalSeconds": 30,
        "DefaultFrom": "noreply@yourdomain.com",
        "IsTestMode": false
    },

    "Smtp": {
        "Host": "smtp.yourprovider.com",
        "Port": 587,
        "UserName": "smtp_user",
        "Password": "smtp_password",
        "EnableSsl": true,
        "From": "noreply@yourdomain.com"
    },

    "ServiceBus": {
        "ConnectionString": "Endpoint=sb://your-servicebus.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY",
        "QueueName": "emailqueue",
        "MaxConcurrentCalls": 5,
        "MessageProcessingTimeoutSeconds": 60
    },

    "ConnectionStrings": {
        "EmailDb": "Server=.;Database=EmailServiceDb;Trusted_Connection=True;TrustServerCertificate=True"
    },

    "AllowedHosts": "*"
}
