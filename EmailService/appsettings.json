{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "EmailOptions": {
        "SendDelayMilliseconds": 100,
        "MaxRetryCount": 3,
        "RetryIntervalSeconds": 30,
        "DefaultFrom": "noreply@yourdomain.com",
        "IsTestMode": false
    },

    "Smtp": {
        "Host": "smtp.yourprovider.com",
        "Port": 587,
        "UserName": "smtp_user",
        "Password": "smtp_password",
        "EnableSsl": true,
        "From": "noreply@yourdomain.com"
    },

    "ServiceBus": {
        "ConnectionString": "Endpoint=sb://unilink-mail.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=w0FOPcHCU3juUPk96+07X5VSCfy+066rw+ASbK8x114=",
        "QueueName": "mailservice",
        "MaxConcurrentCalls": 5,
        "MessageProcessingTimeoutSeconds": 60
    },

    "ConnectionStrings": {
        "EmailDb": "Server=(localdb)\\MSSQLLocalDB;Database=EmailServiceDb;Trusted_Connection=True;"
    },

    "Templates": {
        "TemplatePath": "Infrastructure/Templates",
        "Extension": ".cshtml"
    },

    "AllowedHosts": "*"
}
