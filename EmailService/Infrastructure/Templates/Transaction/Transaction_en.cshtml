@using EmailService.Application.Models.Transaction

@model TransactionModel

@{
    Layout = "Layouts/_LayoutTransaction.cshtml";
}

<p class="text">
    Dear user,
</p>

<p class="text">
    This email was provided as a contact address for account recovery and security notifications.
    To ensure that this email address belongs to you, please confirm it.
</p>

<p class="text">
    Enter the following verification code in the confirmation form:
</p>

<div style="text-align:center; margin: 25px 0;">
    <span style="
        display:inline-block;
        font-size:28px;
        font-weight:bold;
        letter-spacing:4px;
        color:#333;
        background:#f0f0f0;
        padding:12px 20px;
        border-radius:6px;">
        @Model.Code
    </span>
</div>

<p class="text">
    The code is valid for <strong>1 hour</strong> and can only be used once.
</p>

<p class="text">
    If you did not request this verification or this email is not related to you,
    please ignore this message.
</p>

<p class="text">
    Best regards,<br />
    <strong>UNILINK Team</strong>
</p>